# Import TensorFlow library
import tensorflow as tf

# Import dataset, layers and model modules
from tensorflow.keras import datasets, layers, models

# ---------- Load Dataset ----------

# Load Fashion MNIST dataset
# x_train -> training images
# y_train -> training labels
# x_test -> testing images
# y_test -> testing labels

(x_train, y_train), (x_test, y_test) = datasets.fashion_mnist.load_data()

# ---------- Data Preprocessing ----------

# Normalize pixel values between 0 and 1
# Original range is 0 to 255

x_train = x_train / 255.0
x_test = x_test / 255.0

# Reshape images for CNN
# 28x28 image with 1 color channel

x_train = x_train.reshape((60000, 28, 28, 1))
x_test = x_test.reshape((10000, 28, 28, 1))

# ---------- Create CNN Model ----------

# Create sequential model
model = models.Sequential()

# Add convolution layer
# 32 filters of size 3x3
# ReLU activation function

model.add(layers.Conv2D(32, (3,3),
                        activation='relu',
                        input_shape=(28,28,1)))

# Add max pooling layer
# Reduces image size

model.add(layers.MaxPooling2D((2,2)))

# Convert 2D data into 1D vector

model.add(layers.Flatten())

# Add fully connected hidden layer

model.add(layers.Dense(64, activation='relu'))

# Output layer
# 10 classes in Fashion MNIST dataset

model.add(layers.Dense(10, activation='softmax'))

# ---------- Compile Model ----------

# Adam -> optimizer
# sparse_categorical_crossentropy -> loss function
# accuracy -> evaluation metric

model.compile(optimizer='adam',
              loss='sparse_categorical_crossentropy',
              metrics=['accuracy'])

# ---------- Train Model ----------

# Train model for 5 epochs

model.fit(x_train, y_train, epochs=5)

# ---------- Evaluate Model ----------

# Evaluate model on test dataset

test_loss, test_acc = model.evaluate(x_test, y_test)

# ---------- Print Accuracy ----------

print("Test Accuracy :", test_acc)